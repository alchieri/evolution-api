# Evolution API - Production baseline
# ⚠️ Do not commit real secrets. Inject values via AWS Secrets Manager/SSM in ECS Task Definition.

SERVER_NAME=evolution
SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=https://SEU_DOMINIO_API

# Telemetry
TELEMETRY_ENABLED=false

# Logging
LOG_LEVEL=ERROR,WARN,INFO
LOG_COLOR=false
LOG_BAILEYS=error

# Database
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://<user>:<pass>@<rds-endpoint>:5432/<db>?schema=evolution_api&sslmode=require
DATABASE_CONNECTION_CLIENT_NAME=evolution_exchange

# Cache
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://<elasticache-endpoint>:6379/6
CACHE_REDIS_TTL=604800
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

# Authentication
AUTHENTICATION_API_KEY=<chave-forte>
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=false

# Keep optional integrations disabled to reduce operational surface
RABBITMQ_ENABLED=false
SQS_ENABLED=false
KAFKA_ENABLED=false
WEBSOCKET_ENABLED=false
PUSHER_ENABLED=false
WEBHOOK_GLOBAL_ENABLED=false

# Chatbot / AI integrations
TYPEBOT_ENABLED=false
CHATWOOT_ENABLED=false
OPENAI_ENABLED=false
DIFY_ENABLED=false
N8N_ENABLED=false
EVOAI_ENABLED=false

# Storage integrations
S3_ENABLED=false

# Baileys channel
# Use instance creation API with integration=WHATSAPP-BAILEYS.
# The project already contains Baileys service/route support.
